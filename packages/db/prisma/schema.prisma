generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  ADMIN
  MEMBER
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships  OrganizationMembership[]
}

model Organization {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  memberships OrganizationMembership[]
  projects    Project[]
}

model OrganizationMembership {
  id             String   @id @default(cuid())
  role           Role
  createdAt      DateTime @default(now())

  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String

  @@unique([userId, organizationId])
  @@index([organizationId])
}

model Project {
  id             String   @id @default(cuid())
  name           String
  slug           String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String
  queues         Queue[]

  @@unique([organizationId, slug])
  @@index([organizationId])
}

enum RetryStrategy {
  FIXED
  LINEAR
  EXPONENTIAL
}

model Queue {
  id               String   @id @default(cuid())
  name             String
  priority         Int      @default(0)
  concurrencyLimit Int      @default(1)
  isPaused         Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId        String
  retryPolicy      RetryPolicy?
  jobs             Job[]

  // projectId is already the leftmost column of the unique index below,
  // so a separate @@index([projectId]) would be redundant (left-prefix rule).
  @@unique([projectId, name])
}

model RetryPolicy {
  id               String        @id @default(cuid())
  strategy         RetryStrategy @default(FIXED)
  maxAttempts      Int           @default(3)
  baseDelaySeconds Int           @default(30)
  maxDelaySeconds  Int           @default(3600)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  queue            Queue  @relation(fields: [queueId], references: [id], onDelete: Cascade)
  queueId          String @unique
}

enum JobType {
  IMMEDIATE
  DELAYED
  SCHEDULED
}

// CLAIMED/RUNNING/COMPLETED/FAILED/DEAD_LETTER are not produced by any
// endpoint yet — Phase 3 only ever creates QUEUED or SCHEDULED jobs. The
// full set is defined now so the worker (Phase 4) and retry/DLQ logic
// (Phase 5) don't require another enum migration.
enum JobStatus {
  SCHEDULED
  QUEUED
  CLAIMED
  RUNNING
  COMPLETED
  FAILED
  DEAD_LETTER
  CANCELLED
}

model Job {
  id               String    @id @default(cuid())
  // Identifies which registered worker handler executes this job (e.g.
  // "send-email"). Added in Phase 4 — Phase 3 only modeled *when* a job
  // runs (type/runAt), not *what* it runs; the worker can't dispatch
  // execution without this.
  name             String
  type             JobType
  status           JobStatus
  payload          Json
  runAt            DateTime
  attempts         Int       @default(0)

  // Snapshotted from the queue's RetryPolicy at creation time (with optional
  // per-job override) so later edits to the queue's default policy don't
  // retroactively change jobs already in flight.
  retryStrategy    RetryStrategy
  maxAttempts      Int
  baseDelaySeconds Int
  maxDelaySeconds  Int

  idempotencyKey   String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  queue            Queue   @relation(fields: [queueId], references: [id], onDelete: Cascade)
  queueId          String

  worker           Worker? @relation(fields: [workerId], references: [id], onDelete: SetNull)
  workerId         String?
  claimedAt        DateTime?
  startedAt        DateTime?
  completedAt      DateTime?
  lastError        String?

  @@unique([queueId, idempotencyKey])
  @@index([status, runAt])
}

enum WorkerStatus {
  ACTIVE
  DRAINING
  OFFLINE
}

model Worker {
  id            String       @id @default(cuid())
  hostname      String
  pid           Int
  status        WorkerStatus @default(ACTIVE)
  concurrency   Int
  startedAt     DateTime     @default(now())
  stoppedAt     DateTime?
  // Denormalized "latest heartbeat" for O(1) liveness checks, so a health
  // check doesn't have to query/sort WorkerHeartbeat. The heartbeat table
  // still keeps full history for the worker-health-over-time dashboard view.
  lastSeenAt    DateTime     @default(now())
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  jobs          Job[]
  heartbeats    WorkerHeartbeat[]
}

model WorkerHeartbeat {
  id         String   @id @default(cuid())
  activeJobs Int      @default(0)
  createdAt  DateTime @default(now())

  worker     Worker @relation(fields: [workerId], references: [id], onDelete: Cascade)
  workerId   String

  @@index([workerId, createdAt])
}