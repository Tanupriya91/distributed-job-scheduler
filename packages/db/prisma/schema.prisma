generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  ADMIN
  MEMBER
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships  OrganizationMembership[]
}

model Organization {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  memberships OrganizationMembership[]
  projects    Project[]
}

model OrganizationMembership {
  id             String   @id @default(cuid())
  role           Role
  createdAt      DateTime @default(now())

  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String

  @@unique([userId, organizationId])
  @@index([organizationId])
}

model Project {
  id             String   @id @default(cuid())
  name           String
  slug           String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String
  queues         Queue[]

  @@unique([organizationId, slug])
  @@index([organizationId])
}

enum RetryStrategy {
  FIXED
  LINEAR
  EXPONENTIAL
}

model Queue {
  id               String   @id @default(cuid())
  name             String
  priority         Int      @default(0)
  concurrencyLimit Int      @default(1)
  isPaused         Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId        String
  retryPolicy      RetryPolicy?
  jobs             Job[]
  recurringJobs    RecurringJob[]
  jobBatches       JobBatch[]

  // projectId is already the leftmost column of the unique index below,
  // so a separate @@index([projectId]) would be redundant (left-prefix rule).
  @@unique([projectId, name])
}

model RetryPolicy {
  id               String        @id @default(cuid())
  strategy         RetryStrategy @default(FIXED)
  maxAttempts      Int           @default(3)
  baseDelaySeconds Int           @default(30)
  maxDelaySeconds  Int           @default(3600)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  queue            Queue  @relation(fields: [queueId], references: [id], onDelete: Cascade)
  queueId          String @unique
}

enum JobType {
  IMMEDIATE
  DELAYED
  SCHEDULED
  RECURRING
}

// CLAIMED/RUNNING/COMPLETED/FAILED/DEAD_LETTER are not produced by any
// endpoint yet — Phase 3 only ever creates QUEUED or SCHEDULED jobs. The
// full set is defined now so the worker (Phase 4) and retry/DLQ logic
// (Phase 5) don't require another enum migration.
enum JobStatus {
  SCHEDULED
  QUEUED
  CLAIMED
  RUNNING
  COMPLETED
  FAILED
  DEAD_LETTER
  CANCELLED
}

model Job {
  id               String    @id @default(cuid())
  // Identifies which registered worker handler executes this job (e.g.
  // "send-email"). Added in Phase 4 — Phase 3 only modeled *when* a job
  // runs (type/runAt), not *what* it runs; the worker can't dispatch
  // execution without this.
  name             String
  type             JobType
  status           JobStatus
  payload          Json
  runAt            DateTime
  attempts         Int       @default(0)

  // Snapshotted from the queue's RetryPolicy at creation time (with optional
  // per-job override) so later edits to the queue's default policy don't
  // retroactively change jobs already in flight.
  retryStrategy    RetryStrategy
  maxAttempts      Int
  baseDelaySeconds Int
  maxDelaySeconds  Int

  idempotencyKey   String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  queue            Queue   @relation(fields: [queueId], references: [id], onDelete: Cascade)
  queueId          String

  worker           Worker? @relation(fields: [workerId], references: [id], onDelete: SetNull)
  workerId         String?
  claimedAt        DateTime?
  startedAt        DateTime?
  completedAt      DateTime?
  lastError        String?

  // Set when this job was spawned by a RecurringJob firing, or submitted
  // as part of a batch. Both nullable — most jobs are neither.
  recurringJob     RecurringJob? @relation(fields: [recurringJobId], references: [id], onDelete: SetNull)
  recurringJobId   String?
  batch            JobBatch?     @relation(fields: [batchId], references: [id], onDelete: SetNull)
  batchId          String?

  executions       JobExecution[]
  deadLetter       DeadLetterQueue?

  @@unique([queueId, idempotencyKey])
  @@index([status, runAt])
  @@index([recurringJobId])
  @@index([batchId])
}

enum JobExecutionStatus {
  COMPLETED
  FAILED
}

// One row per execution ATTEMPT (not per job) — this is the "retry history"
// the assignment's DB design calls for. Job itself only ever holds the
// latest attempt's denormalized fields (lastError, startedAt, completedAt);
// this table is the append-only audit trail across all attempts.
model JobExecution {
  id            String             @id @default(cuid())
  attemptNumber Int
  status        JobExecutionStatus
  startedAt     DateTime
  completedAt   DateTime
  error         String?
  createdAt     DateTime           @default(now())

  job           Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  jobId         String

  worker        Worker? @relation(fields: [workerId], references: [id], onDelete: SetNull)
  workerId      String?

  @@index([jobId, attemptNumber])
}

// A permanent record that a job exhausted its retry budget. Kept separate
// from Job.status=DEAD_LETTER (which still exists for fast filtering) so
// there's a dedicated, purpose-built resource for the dashboard's "Dead
// Letter Queue" view and a place to record manual-retry history
// (retriedAt) without overloading the Job row itself.
model DeadLetterQueue {
  id        String    @id @default(cuid())
  reason    String
  failedAt  DateTime  @default(now())
  retriedAt DateTime?
  createdAt DateTime  @default(now())

  job       Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  jobId     String @unique
}

// A cron-based job definition — the template that periodically spawns real
// Job rows. Named RecurringJob (not "ScheduledJob", despite the assignment's
// DB-design wording) to avoid clashing with the already-shipped
// Job.type=SCHEDULED, which means something different: a one-time job with
// a future runAt, not a repeating cron template.
model RecurringJob {
  id               String        @id @default(cuid())
  name             String
  cronExpression   String
  payload          Json
  isPaused         Boolean       @default(false)
  nextRunAt        DateTime
  lastRunAt        DateTime?

  retryStrategy    RetryStrategy
  maxAttempts      Int
  baseDelaySeconds Int
  maxDelaySeconds  Int

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  queue            Queue  @relation(fields: [queueId], references: [id], onDelete: Cascade)
  queueId          String
  jobs             Job[]

  @@unique([queueId, name])
  @@index([nextRunAt])
}

// A group of jobs submitted together in one request, so the dashboard can
// show aggregate progress ("120/500 completed") instead of 500 unrelated
// rows. Deliberately minimal: all jobs in a batch share the same type
// (IMMEDIATE) and the queue's default retry policy — mixing scheduling
// semantics within one batch would add complexity the assignment doesn't
// ask for.
model JobBatch {
  id        String   @id @default(cuid())
  name      String?
  totalJobs Int
  createdAt DateTime @default(now())

  queue     Queue  @relation(fields: [queueId], references: [id], onDelete: Cascade)
  queueId   String
  jobs      Job[]

  @@index([queueId])
}

enum WorkerStatus {
  ACTIVE
  DRAINING
  OFFLINE
}

model Worker {
  id            String       @id @default(cuid())
  hostname      String
  pid           Int
  status        WorkerStatus @default(ACTIVE)
  concurrency   Int
  startedAt     DateTime     @default(now())
  stoppedAt     DateTime?
  // Denormalized "latest heartbeat" for O(1) liveness checks, so a health
  // check doesn't have to query/sort WorkerHeartbeat. The heartbeat table
  // still keeps full history for the worker-health-over-time dashboard view.
  lastSeenAt    DateTime     @default(now())
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  jobs          Job[]
  heartbeats    WorkerHeartbeat[]
  jobExecutions JobExecution[]
}

model WorkerHeartbeat {
  id         String   @id @default(cuid())
  activeJobs Int      @default(0)
  createdAt  DateTime @default(now())

  worker     Worker @relation(fields: [workerId], references: [id], onDelete: Cascade)
  workerId   String

  @@index([workerId, createdAt])
}